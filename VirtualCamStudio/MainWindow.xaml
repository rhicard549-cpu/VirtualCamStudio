<Window x:Class="VirtualCamStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirtualCam Studio"
        Height="800"
        Width="1200"
        Background="#202020"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0"
              Grid.ColumnSpan="3"
              Background="#1a1a1a"
              Foreground="White">

            <MenuItem Header="_File"
                      Foreground="White">
                <MenuItem Header="Export Current Frame..."
                          Click="ExportCurrentFrame_Click"/>
            </MenuItem>

        </Menu>

        <!-- ToolBar -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="#1a1a1a"
                BorderBrush="#444"
                BorderThickness="0,0,0,1"
                Padding="10,0,10,0"
                VerticalAlignment="Stretch">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Camera Profile:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="CameraProfileComboBox"
                          Width="200"
                          Height="28"
                          VerticalAlignment="Center"
                          SelectionChanged="CameraProfileComboBox_SelectionChanged">

                </ComboBox>

                <!-- Start Unity Video Capture Button -->
                <Button x:Name="StartUnityCaptureButton"
                        Content="Start Unity Video Capture"
                        Width="200"
                        Height="28"
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        Background="#0066cc"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="StartUnityCaptureButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0077dd"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0055aa"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Stop Unity Video Capture Button -->
                <Button x:Name="StopUnityCaptureButton"
                        Content="Stop Unity Video Capture"
                        Width="200"
                        Height="28"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Background="#cc0000"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="StopUnityCaptureButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#dd0000"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#aa0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#555555"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Separator -->
                <Border Width="1"
                        Height="24"
                        Background="#444"
                        Margin="15,0,15,0"
                        VerticalAlignment="Center"/>

                <!-- Temporary Video Playback Controls -->
                <TextBlock Text="Video:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>

                <Button x:Name="PlayButton"
                        Content="▶ Play"
                        Width="80"
                        Height="28"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Background="#00aa00"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="PlayButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00cc00"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#008800"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#444"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="PauseButton"
                        Content="⏸ Pause"
                        Width="80"
                        Height="28"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Background="#ff8800"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="PauseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#ff9900"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#dd7700"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#444"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="StopButton"
                        Content="⏹ Stop"
                        Width="80"
                        Height="28"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Background="#cc0000"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="StopButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#dd1111"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#aa0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#444"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <CheckBox x:Name="LoopCheckBox"
                          Content="Loop"
                          Foreground="White"
                          VerticalAlignment="Center"
                          FontWeight="SemiBold"
                          IsEnabled="False"
                          Checked="LoopCheckBox_Changed"
                          Unchecked="LoopCheckBox_Changed"/>

                <!-- Audio Separator -->
                <Border Width="1"
                        Height="24"
                        Background="#444"
                        Margin="15,0,15,0"
                        VerticalAlignment="Center"/>

                <!-- Audio Playback Controls -->
                <TextBlock Text="Audio:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="AudioDeviceComboBox"
                          Width="180"
                          Height="28"
                          VerticalAlignment="Center"
                          Margin="0,0,5,0"
                          SelectionChanged="AudioDeviceComboBox_SelectionChanged"
                          ToolTip="Select audio output device (must be set to Windows default mic for CloudPhone)">
                </ComboBox>

                <Button x:Name="LoadAudioButton"
                        Content="📂 Load"
                        Width="80"
                        Height="28"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Background="#5555cc"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="LoadAudioButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#6666dd"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#4444aa"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="PlayAudioButton"
                        Content="▶"
                        Width="40"
                        Height="28"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Background="#00aa00"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="PlayAudioButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00cc00"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#008800"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#444"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="PauseAudioButton"
                        Content="⏸"
                        Width="40"
                        Height="28"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Background="#ff8800"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="PauseAudioButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#ff9900"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#dd7700"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#444"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="StopAudioButton"
                        Content="⏹"
                        Width="40"
                        Height="28"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Background="#cc0000"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="StopAudioButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#dd0000"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#aa0000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#444"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <CheckBox x:Name="LoopAudioCheckBox"
                          Content="Loop"
                          Foreground="White"
                          VerticalAlignment="Center"
                          FontWeight="SemiBold"
                          IsEnabled="False"
                          Checked="LoopAudioCheckBox_Changed"
                          Unchecked="LoopAudioCheckBox_Changed"/>

            </StackPanel>

        </Border>

        <!-- Media Library Panel -->

        <Border Grid.Row="2"
                Grid.Column="0"
                Margin="15,15,0,15"
                Background="#2A2A2A"
                CornerRadius="8"
                BorderBrush="#555"
                BorderThickness="2">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="Media"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="10,8,10,8"
                           HorizontalAlignment="Center"/>

                <!-- Media List -->
                <ListBox x:Name="MediaListBox"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="MediaListBox_SelectionChanged"
                         Margin="5"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#333"
                                    CornerRadius="4"
                                    Padding="5"
                                    Margin="2">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Thumbnail -->
                                    <Image Grid.Row="0"
                                           Source="{Binding Thumbnail}"
                                           Width="150"
                                           Height="100"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Margin="0,0,0,5"/>

                                    <!-- Filename -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding FileName}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,2"/>

                                    <!-- File Type -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding FileType}"
                                               Foreground="#AAA"
                                               FontSize="10"/>

                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="10">

                    <Button x:Name="DeleteButton"
                            Content="Delete"
                            Click="DeleteButton_Click"
                            Padding="10,5"
                            Margin="0,0,5,0"
                            Background="#444"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="#666"/>

                    <Button x:Name="ClearButton"
                            Content="Clear"
                            Click="ClearButton_Click"
                            Padding="10,5"
                            Margin="5,0,0,0"
                            Background="#444"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="#666"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- Preview -->

        <Border Grid.Row="2"
                Grid.Column="1"
                Margin="15"
                CornerRadius="8"
                BorderBrush="#555"
                BorderThickness="2"
                Background="#2A2A2A"
                x:Name="PreviewBorder"
                MouseDown="PreviewBorder_MouseDown"
                MouseUp="PreviewBorder_MouseUp"
                MouseMove="PreviewBorder_MouseMove"
                MouseWheel="PreviewBorder_MouseWheel">

            <Grid x:Name="PreviewGrid">

                <!-- Checkerboard Background for Transparency -->
                <Rectangle x:Name="CheckerboardBackground"
                           Visibility="Collapsed">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,16,16"
                                      ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#CCCCCC">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,16,16"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#999999">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,8,8"/>
                                                <RectangleGeometry Rect="8,8,8,8"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Image x:Name="PreviewImage"
                       Stretch="Uniform"/>

                <!-- Safe Area Overlay -->
                <Canvas x:Name="SafeAreaOverlay"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">

                    <!-- Action Safe Area (90%) -->
                    <Rectangle x:Name="ActionSafeRect"
                               Stroke="#FFFF00"
                               StrokeThickness="2"
                               StrokeDashArray="4,2"
                               Fill="Transparent"/>

                    <!-- Title Safe Area (95%) -->
                    <Rectangle x:Name="TitleSafeRect"
                               Stroke="#00FF00"
                               StrokeThickness="1"
                               StrokeDashArray="2,2"
                               Fill="Transparent"/>

                </Canvas>

                <TextBlock x:Name="DropText"
                           Text="📁 Drag an Image or Video Here"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

        <!-- Right Panel -->

        <Border Grid.Row="2"
                Grid.Column="2"
                Margin="10,15,15,15"
                Background="#2A2A2A"
                CornerRadius="8"
                Padding="15">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <TextBlock Text="📱 Virtual Camera"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Phone Camera"
                               Foreground="White"
                               FontWeight="Bold"/>

                    <TextBlock Text="Phone Profile"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               Margin="0,5,0,2"/>

                    <ComboBox x:Name="PhoneProfileComboBox"
                              Margin="0,0,0,10"
                              SelectionChanged="PhoneProfileComboBox_SelectionChanged"/>

                    <CheckBox x:Name="VerificationModeCheckBox"
                              Content="☑ Verification Mode"
                              Foreground="White"
                              IsChecked="True"
                              Margin="0,0,0,5"
                              Checked="VerificationModeCheckBox_Changed"
                              Unchecked="VerificationModeCheckBox_Changed"
                              ToolTip="Optimized for document capture (slower, more precise)"/>

                    <CheckBox x:Name="HandheldModeCheckBox"
                              Content="☐ Handheld Mode"
                              Foreground="White"
                              Margin="0,0,0,15"
                              Checked="HandheldModeCheckBox_Changed"
                              Unchecked="HandheldModeCheckBox_Changed"
                              ToolTip="Subtle breathing and motion simulation"/>

                    <Separator Margin="0,5"/>

                    <TextBlock Text="Fit Mode"
                               Foreground="White"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="FitModeComboBox"
                              Margin="0,5,0,15">

                        <ComboBoxItem IsSelected="True">Auto</ComboBoxItem>
                        <ComboBoxItem>Fill</ComboBoxItem>
                        <ComboBoxItem>Fit</ComboBoxItem>
                        <ComboBoxItem>Smart Crop</ComboBoxItem>

                    </ComboBox>

                    <Separator Margin="0,5"/>

                    <TextBlock Text="Camera Distance"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="ZoomValueText"
                               Text="100%"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,5"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Near" 
                                   Foreground="#999999"
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>

                        <Slider x:Name="ZoomSlider"
                                Grid.Column="1"
                                Minimum="1"
                                Maximum="5"
                                Value="1"
                                TickFrequency="0.01"
                                SmallChange="0.01"
                                LargeChange="0.10"
                                ValueChanged="ZoomSlider_ValueChanged"/>

                        <TextBlock Text="Far" 
                                   Grid.Column="2"
                                   Foreground="#999999"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"/>
                    </Grid>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Camera Position"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Left / Right"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               Margin="0,0,0,2"/>

                    <TextBlock x:Name="HorizontalValueText"
                               Text="0"
                               Foreground="#888888"
                               FontSize="10"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="XSlider"
                            Minimum="-500"
                            Maximum="500"
                            Value="0"
                            ValueChanged="XSlider_ValueChanged"/>

                    <TextBlock Text="Forward / Back"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               Margin="0,10,0,2"/>

                    <TextBlock x:Name="VerticalValueText"
                               Text="0"
                               Foreground="#888888"
                               FontSize="10"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="YSlider"
                            Minimum="-500"
                            Maximum="500"
                            Value="0"
                            ValueChanged="YSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Camera Tilt"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Pitch"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               Margin="0,0,0,2"/>

                    <TextBlock x:Name="PitchValueText"
                               Text="0°"
                               Foreground="#888888"
                               FontSize="10"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="PitchSlider"
                            Minimum="-12"
                            Maximum="12"
                            Value="0"
                            ValueChanged="PitchSlider_ValueChanged"/>

                    <TextBlock Text="Yaw"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               Margin="0,10,0,2"/>

                    <TextBlock x:Name="YawValueText"
                               Text="0°"
                               Foreground="#888888"
                               FontSize="10"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="YawSlider"
                            Minimum="-12"
                            Maximum="12"
                            Value="0"
                            ValueChanged="YawSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Camera Roll"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="RotationValueText"
                               Text="0°"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="RotationSlider"
                            Minimum="-15"
                            Maximum="15"
                            Value="0"
                            ValueChanged="RotationSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Viewport Options"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <CheckBox x:Name="ShowCheckerboardCheckBox"
                              Content="Show Checkerboard"
                              Foreground="White"
                              Margin="0,5,0,5"
                              Checked="ShowCheckerboardCheckBox_Changed"
                              Unchecked="ShowCheckerboardCheckBox_Changed"/>

                    <CheckBox x:Name="ShowSafeAreaCheckBox"
                              Content="Show Safe Area"
                              Foreground="White"
                              Margin="0,0,0,15"
                              Checked="ShowSafeAreaCheckBox_Changed"
                              Unchecked="ShowSafeAreaCheckBox_Changed"/>

                    <Separator Margin="0,0,0,10"/>

                    <CheckBox x:Name="RememberFramingCheckBox"
                              Content="Remember Framing"
                              Foreground="White"
                              Margin="0,0,0,15"/>

                    <Button x:Name="ResetButton"
                            Content="↺ Reset Camera"
                            Height="36"
                            Click="ResetButton_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- Status Bar -->

        <StatusBar Grid.Row="3"
                   Grid.ColumnSpan="3">

            <StatusBarItem>

                <TextBlock x:Name="StatusText"
                           Text="Ready"/>

            </StatusBarItem>

            <Separator/>

            <StatusBarItem>

                <TextBlock x:Name="ResolutionText"
                           Text="1080 × 1920 @30 FPS"/>

            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Unity Video Capture: "
                               Margin="0,0,5,0"/>
                    <Ellipse x:Name="UnityCaptureStatusIndicator"
                             Width="10"
                             Height="10"
                             Fill="Gray"
                             Margin="0,0,5,0"/>
                    <TextBlock x:Name="UnityCaptureStatusText"
                               Text="Stopped"/>
                </StackPanel>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock x:Name="UnityCaptureSenderStatusText"
                           Text="Sender: Starting..."
                           Foreground="Gray"/>
            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>
