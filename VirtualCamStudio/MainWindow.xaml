<Window x:Class="VirtualCamStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirtualCam Studio"
        Height="800"
        Width="1200"
        Background="#202020"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        Loaded="Window_Loaded">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*" />
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0"
              Grid.ColumnSpan="3"
              Background="#1a1a1a"
              Foreground="White">

            <MenuItem Header="_File"
                      Foreground="White">
                <MenuItem Header="Export Current Frame..."
                          Click="ExportCurrentFrame_Click"/>
            </MenuItem>

        </Menu>

        <!-- ToolBar -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="#1a1a1a"
                BorderBrush="#444"
                BorderThickness="0,0,0,1"
                Padding="10,0,10,0"
                VerticalAlignment="Stretch">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Camera Profile:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="CameraProfileComboBox"
                          Width="200"
                          Height="28"
                          VerticalAlignment="Center"
                          SelectionChanged="CameraProfileComboBox_SelectionChanged">

                </ComboBox>

                <!-- Temporary OBS Test Button -->
                <Button x:Name="ConnectOBSButton"
                        Content="Connect OBS"
                        Width="120"
                        Height="28"
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        Background="#0066cc"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ConnectOBSButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0077dd"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0055aa"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Border>

        <!-- Media Library Panel -->

        <Border Grid.Row="2"
                Grid.Column="0"
                Margin="15,15,0,15"
                Background="#2A2A2A"
                CornerRadius="8"
                BorderBrush="#555"
                BorderThickness="2">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="Media"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="10,8,10,8"
                           HorizontalAlignment="Center"/>

                <!-- Media List -->
                <ListBox x:Name="MediaListBox"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="MediaListBox_SelectionChanged"
                         Margin="5"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#333"
                                    CornerRadius="4"
                                    Padding="5"
                                    Margin="2">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Thumbnail -->
                                    <Image Grid.Row="0"
                                           Source="{Binding Thumbnail}"
                                           Width="150"
                                           Height="100"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Margin="0,0,0,5"/>

                                    <!-- Filename -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding FileName}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,2"/>

                                    <!-- File Type -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding FileType}"
                                               Foreground="#AAA"
                                               FontSize="10"/>

                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="10">

                    <Button x:Name="DeleteButton"
                            Content="Delete"
                            Click="DeleteButton_Click"
                            Padding="10,5"
                            Margin="0,0,5,0"
                            Background="#444"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="#666"/>

                    <Button x:Name="ClearButton"
                            Content="Clear"
                            Click="ClearButton_Click"
                            Padding="10,5"
                            Margin="5,0,0,0"
                            Background="#444"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="#666"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- Preview -->

        <Border Grid.Row="2"
                Grid.Column="1"
                Margin="15"
                CornerRadius="8"
                BorderBrush="#555"
                BorderThickness="2"
                Background="#2A2A2A"
                x:Name="PreviewBorder"
                MouseDown="PreviewBorder_MouseDown"
                MouseUp="PreviewBorder_MouseUp"
                MouseMove="PreviewBorder_MouseMove"
                MouseWheel="PreviewBorder_MouseWheel">

            <Grid x:Name="PreviewGrid">

                <!-- Checkerboard Background for Transparency -->
                <Rectangle x:Name="CheckerboardBackground"
                           Visibility="Collapsed">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,16,16"
                                      ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#CCCCCC">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,16,16"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="#999999">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <RectangleGeometry Rect="0,0,8,8"/>
                                                <RectangleGeometry Rect="8,8,8,8"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Image x:Name="PreviewImage"
                       Stretch="Uniform"/>

                <!-- Safe Area Overlay -->
                <Canvas x:Name="SafeAreaOverlay"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">

                    <!-- Action Safe Area (90%) -->
                    <Rectangle x:Name="ActionSafeRect"
                               Stroke="#FFFF00"
                               StrokeThickness="2"
                               StrokeDashArray="4,2"
                               Fill="Transparent"/>

                    <!-- Title Safe Area (95%) -->
                    <Rectangle x:Name="TitleSafeRect"
                               Stroke="#00FF00"
                               StrokeThickness="1"
                               StrokeDashArray="2,2"
                               Fill="Transparent"/>

                </Canvas>

                <TextBlock x:Name="DropText"
                           Text="📁 Drag an Image or Video Here"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

        <!-- Right Panel -->

        <Border Grid.Row="2"
                Grid.Column="2"
                Margin="10,15,15,15"
                Background="#2A2A2A"
                CornerRadius="8"
                Padding="15">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <TextBlock Text="Fit Mode"
                               Foreground="White"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="FitModeComboBox"
                              Margin="0,5,0,15">

                        <ComboBoxItem IsSelected="True">Auto</ComboBoxItem>
                        <ComboBoxItem>Fill</ComboBoxItem>
                        <ComboBoxItem>Fit</ComboBoxItem>
                        <ComboBoxItem>Smart Crop</ComboBoxItem>

                    </ComboBox>

                    <Separator Margin="0,5"/>

                    <TextBlock Text="Zoom"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="ZoomValueText"
                               Text="100%"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="ZoomSlider"
                            Minimum="1"
                            Maximum="5"
                            Value="1"
                            TickFrequency="0.01"
                            SmallChange="0.01"
                            LargeChange="0.10"
                            ValueChanged="ZoomSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Horizontal"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="HorizontalValueText"
                               Text="0"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="XSlider"
                            Minimum="-500"
                            Maximum="500"
                            Value="0"
                            ValueChanged="XSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Vertical"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="VerticalValueText"
                               Text="0"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="YSlider"
                            Minimum="-500"
                            Maximum="500"
                            Value="0"
                            ValueChanged="YSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Rotation"
                               Foreground="White"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="RotationValueText"
                               Text="0°"
                               Foreground="#BBBBBB"
                               Margin="0,0,0,5"/>

                    <Slider x:Name="RotationSlider"
                            Minimum="-180"
                            Maximum="180"
                            Value="0"
                            ValueChanged="RotationSlider_ValueChanged"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Viewport Options"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <CheckBox x:Name="ShowCheckerboardCheckBox"
                              Content="Show Checkerboard"
                              Foreground="White"
                              Margin="0,5,0,5"
                              Checked="ShowCheckerboardCheckBox_Changed"
                              Unchecked="ShowCheckerboardCheckBox_Changed"/>

                    <CheckBox x:Name="ShowSafeAreaCheckBox"
                              Content="Show Safe Area"
                              Foreground="White"
                              Margin="0,0,0,15"
                              Checked="ShowSafeAreaCheckBox_Changed"
                              Unchecked="ShowSafeAreaCheckBox_Changed"/>

                    <Separator Margin="0,0,0,10"/>

                    <CheckBox x:Name="RememberFramingCheckBox"
                              Content="Remember Framing"
                              Foreground="White"
                              Margin="0,0,0,15"/>

                    <Button x:Name="ResetButton"
                            Content="↺ Reset Framing"
                            Height="36"
                            Click="ResetButton_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- Status Bar -->

        <StatusBar Grid.Row="3"
                   Grid.ColumnSpan="3">

            <StatusBarItem>

                <TextBlock x:Name="StatusText"
                           Text="Ready"/>

            </StatusBarItem>

            <Separator/>

            <StatusBarItem>

                <TextBlock x:Name="ResolutionText"
                           Text="1080 × 1920 @30 FPS"/>

            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>